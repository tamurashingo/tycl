{
  "name": "TyCL",
  "scopeName": "source.tycl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#type-annotations" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#symbols" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.tycl",
          "match": ";.*$"
        },
        {
          "name": "comment.block.tycl",
          "begin": "#\\|",
          "end": "\\|#"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tycl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tycl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "type-annotations": {
      "patterns": [
        {
          "name": "meta.type-annotation.tycl",
          "match": "\\[([^\\s\\]]+)\\s+(:[^\\]]+)\\]",
          "captures": {
            "1": { "name": "variable.parameter.tycl" },
            "2": { "name": "storage.type.tycl" }
          }
        },
        {
          "name": "storage.type.keyword.tycl",
          "match": ":(integer|float|double-float|rational|number|string|character|boolean|symbol|keyword|list|vector|array|cons|hash-table|stream|pathname|void|null|t|any)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tycl",
          "match": "\\b(defun|defmacro|defmethod|defclass|defgeneric|defvar|defparameter|defconstant|let|let\\*|flet|labels|if|when|unless|cond|case|do|dolist|dotimes|loop|return|return-from)\\b"
        },
        {
          "name": "keyword.operator.tycl",
          "match": "\\b(and|or|not|eq|eql|equal|equalp)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.tycl",
          "match": "(?<=\\(defun\\s+)[^\\s\\(\\)\\[\\]]+"
        },
        {
          "name": "entity.name.function.tycl",
          "match": "(?<=\\(defmacro\\s+)[^\\s\\(\\)\\[\\]]+"
        },
        {
          "name": "entity.name.function.tycl",
          "match": "(?<=\\(defmethod\\s+)[^\\s\\(\\)\\[\\]]+"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.tycl",
          "match": "\\b(nil|t)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tycl",
          "match": "\\b[0-9]+\\.?[0-9]*\\b"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "variable.other.tycl",
          "match": "[a-zA-Z_][a-zA-Z0-9_\\-]*"
        }
      ]
    }
  }
}
