(in-package #:cl-user)
(defpackage #:sample-project/test/string-utils
  (:use #:cl
        #:rove
        #:sample-project/string-utils))
(in-package #:sample-project/test/string-utils)

(deftest join-string-test
  (ok (string= (join-strings '("a" "b" "c") ", ")
               "a, b, c"))
  (ok (string= (join-strings '("hello") "-")
               "hello")))

(deftest repeat-string-test
  (ok (string= (repeat-string "ab" 3) "ababab"))
  (ok (string= (repeat-string "x" 1) "x"))
  (ok (string= (repeat-string "a" 0) "")))

(deftest truncate-string-test
  (ok (string= (truncate-string "Hello, World!" 5)
               "Hello..."))
  (ok (string= (truncate-string "Hi" 10)
               "Hi")))


